# 应用配置示例文件
# 生产环境建议使用环境变量覆盖敏感配置
# 环境变量格式：KEY__SUBKEY (如：DATASOURCE__PASSWORD)

server:
  cors: http://localhost
  port: 8080
  limit: 1h

log:
  level: info  # debug, info, warn, error

agent:
  enable: false
  flow:
    discover: false
  user:
    concurrency: 3
  item:
    concurrency: 3
    max: 3000
  discover:
    level: 0 # 0-no discover; 1-discover by id; 2-discover by id and domain

datasource:
  driver: mysql
  host: localhost
  port: 3306
  database: mouban
  username: ${DB_USERNAME:-root}        # 或使用环境变量 DB_USERNAME
  password: ${DB_PASSWORD:-changeme}    # 强烈建议使用环境变量设置密码
  charset: utf8mb4
  loc: Asia/Shanghai

http:
  timeout: 10000
  retry_max: 20
  interval:
    user: 4000
    item: 4000
    discover: 4000
  # 格式：<dbcl2_cookie>,<proxy_url>; 多个用分号分隔
  # 示例：http__auth=abc123,http://user:pass@proxy:8080;
  auth: ${HTTP_AUTH:-}
